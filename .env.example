# Supabase Configuration (Required)
VITE_SUPABASE_URL=your-supabase-project-url
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# Backend API URL
VITE_API_URL=http://localhost:5001/api

# Mapbox Configuration (Required for Ambulance Tracking Maps)
# Get free token at: https://account.mapbox.com/access-tokens/
# Free tier: 50,000 maps loads/month
VITE_MAPBOX_TOKEN=pk.your-mapbox-token-here

# OpenAI API Configuration (Optional - for AI chatbot)
VITE_OPENAI_API_KEY=sk-your-openai-api-key

# Groq API Configuration (Optional - free alternative to OpenAI)
# Get free API key from: https://console.groq.com
VITE_GROQ_API_KEY=gsk-your-groq-api-key
VITE_CHATBOT_API_PROVIDER=groq

# Razorpay Configuration (For Payments)
# Get from: https://dashboard.razorpay.com/app/keys
VITE_RAZORPAY_KEY_ID=rzp_your-razorpay-key-id
VITE_RAZORPAY_KEY_SECRET=your-razorpay-key-secret

# Application Configuration
VITE_APP_URL=http://localhost:5173
